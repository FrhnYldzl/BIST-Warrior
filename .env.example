# ═══════════════════════════════════════════════════════════════
# MERIDIAN CAPITAL TÜRKİYE — BIST AI Analist (Midas Destekli)
# ═══════════════════════════════════════════════════════════════

# ─── ÇALIŞMA MODU ──────────────────────────────────────────────
# "analyst"    = AI analiz yapar, SİNYAL üretir. Emir YOK — sen Midas'tan elle girersin (ÖNERİLEN)
# "auto"       = Claude kararlarını broker'a otomatik gönderir (ileri seviye)
OPERATION_MODE=analyst
AUTO_EXECUTE=false

# ─── Broker (analyst modda kullanılmaz, fallback için) ─────────
# "yfinance" = Paper simulator (SQLite, analyst moduna uygun test ortamı)
# "ibkr"     = Interactive Brokers (TWS/Gateway, ileride)
BROKER=yfinance

# ─── Interactive Brokers (opsiyonel, ileride) ──────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_USE_MARKET_DATA=false

# ─── yfinance Paper (varsayılan broker) ────────────────────────
STARTING_CAPITAL_TRY=1000000
COMMISSION_RATE=0.001

# ─── Claude AI (Anthropic) — ZORUNLU ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# ─── Gemini (opsiyonel auditor / council) ─────────────────────
GEMINI_API_KEY=

# ─── Bildirimler (opsiyonel) ──────────────────────────────────
# Resend API (Railway gibi SMTP kısıtlı ortamlar için)
RESEND_API_KEY=
# Gmail SMTP (alternatif)
SMTP_EMAIL=
SMTP_PASSWORD=
# Günlük özet ve alarm e-postaları buraya gider
NOTIFY_EMAIL=
# Yüksek güvenli (≥9/10) sinyal için anında alarm
HIGH_CONFIDENCE_ALERT=true
# Sabah özeti gönderim saati (TRT)
MORNING_BRIEF_HOUR=9
MORNING_BRIEF_MINUTE=45

# ─── Webhook Güvenlik ─────────────────────────────────────────
WEBHOOK_SECRET=buraya-guclu-bir-sifre-yaz

# ─── Uygulama Ayarları ────────────────────────────────────────
PORT=8000
MAX_RISK_PCT=0.02
AI_APPROVAL_REQUIRED=false
TIMEZONE=Europe/Istanbul

# ─── Tarama Kapsamı ───────────────────────────────────────────
# "hybrid" = Focus List + wide-scan (önerilen, mevcut)
# "watchlist" = Sadece Focus List (~100 hisse)
# "full" = Sadece wide-scan top N
SCAN_UNIVERSE=hybrid
PREFILTER_TOP_N=25
